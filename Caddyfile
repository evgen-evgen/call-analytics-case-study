:5000 {
	encode zstd gzip

	redir /grafana /grafana/ 308
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	redir /analysis-api /docs 308

	@analysis_api path /analyze /analyses/* /docs /docs/* /openapi.json /redoc /redoc/*
	handle @analysis_api {
		reverse_proxy analysis-api:8000
	}

	handle {
		reverse_proxy open-webui:8080
	}
}
