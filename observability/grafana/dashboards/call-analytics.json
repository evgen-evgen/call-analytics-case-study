{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"decimals": 0, "unit": "short"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "auto"},
      "targets": [{"expr": "sum(increase(call_analytics_calls_total[$__range])) or vector(0)", "refId": "A"}],
      "title": "Количество звонков",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "green", "value": 75}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "(sum(increase(call_analytics_quality_score_sum[$__range])) / sum(increase(call_analytics_quality_score_count[$__range]))) or vector(0)", "refId": "A"}],
      "title": "Средний quality score",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"decimals": 0, "unit": "short"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {"orientation": "horizontal", "showValue": "always"},
      "targets": [
        {
          "expr": "topk(5, sum by (topic) (increase(call_analytics_calls_total[$__range]))) > 0",
          "format": "time_series",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "Топ тематик",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"decimals": 0, "unit": "short"}},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 8},
      "id": 4,
      "targets": [
        {
          "expr": "sum(increase(call_analytics_calls_total[$__interval]))",
          "legendFormat": "звонки",
          "refId": "A"
        }
      ],
      "title": "Динамика обработанных звонков",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 17},
      "id": 5,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{compose_service=~\"pipelines|analysis-api\"} | json",
          "refId": "A"
        }
      ],
      "title": "Application logs",
      "type": "logs"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 27},
      "id": 6,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{compose_service=~\"pipelines|analysis-api\"} | json | event=~\"operation.failed|request.unexpected_error|analysis_job.failed\"",
          "refId": "A"
        }
      ],
      "title": "Ошибки приложений",
      "type": "logs"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["mtbank", "call-analytics"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timezone": "browser",
  "title": "MTBank Call Analytics",
  "uid": "mtbank-call-analytics",
  "version": 1
}
